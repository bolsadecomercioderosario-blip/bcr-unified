__pycache__/
*.pyc
.env
venv/
backend/static/uploads/*
!backend/static/uploads/.gitkeep
# No subir archivos generados locales si existen
backend/static/lluvias/mapa_lluvias.jpg
backend/static/social/*.pdf
backend/static/social/*.jpg
# Credenciales de Google (Drive/YouTube) — NUNCA commitear.
# Sin barra inicial: matchea en cualquier carpeta (raíz del repo y backend/).
# Cubre también los backups (client_secret_testing.json, token_testing.json).
client_secret*.json
token*.json

# SQLite local (en producción se usa Render Disk; el archivo local nunca debe
# committearse para no pisar accidentalmente la DB de producción al hacer pull)
backend/agenda.db
backend/agenda.db-journal
backend/agenda.db-wal
backend/agenda.db-shm
# DBs locales de desarrollo/preview (ej. la que arma .claude/launch.json)
backend/_*.db
backend/_*.db-journal
backend/_*.db-wal
backend/_*.db-shm

# Logs/artefactos transientes que aparecen al correr la app local
.pip-install.log
.server.log
.claude/