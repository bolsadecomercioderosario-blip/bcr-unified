# Módulo Aapresid (Congreso Aapresid 2026) — variables de entorno (todas opcionales).
# En bcr-unified se setean en Render como env vars del servicio.

# Secreto para firmar los tokens de sesión del módulo. CAMBIAR en producción
# por un valor largo y aleatorio. Si no se setea, usa un default de dev.
AAPRESID_SECRET=cambiar-por-un-valor-largo-y-aleatorio

# Usuario administrador inicial (se crea en el primer arranque, vía seed).
# Si no se setean, el seed crea admin@aapresid.bcr / aapresid2026 (cambiar!).
AAPRESID_ADMIN_EMAIL=admin@aapresid.bcr
AAPRESID_ADMIN_PASSWORD=aapresid2026
